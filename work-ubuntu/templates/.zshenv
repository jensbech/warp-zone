export ZSH=/opt/oh-my-zsh
export EDITOR=vi
export PNPM_HOME="$HOME/.local/share/pnpm"
export GOPATH="$HOME/go"
export RUSTUP_HOME=/usr/local/rustup
export CARGO_HOME="$HOME/.cargo"
export PATH="$HOME/.local/bin:$PNPM_HOME:$HOME/.pulumi/bin:$HOME/.dotnet/tools:$CARGO_HOME/bin:$GOPATH/bin:/usr/local/go/bin:/usr/local/cargo/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
